{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "www.sinapsa.co" }],
      "destination": "https://sinapsa.co/",
      "permanent": true
    },
    {
      "source": "/:path+",
      "has": [{ "type": "host", "value": "www.sinapsa.co" }],
      "destination": "https://sinapsa.co/:path+",
      "permanent": true
    }
  ]
}
